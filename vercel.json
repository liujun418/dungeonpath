{
  "framework": "hugo",
  "buildCommand": "hugo --gc --minify",
  "outputDirectory": "public",
  "git": {
    "deploymentEnabled": {
      "master": true
    }
  },
  "redirects": [
    {
      "source": "https://www.dungeonpath.com/:path(.*)",
      "destination": "https://dungeonpath.com/$1",
      "permanent": true
    }
  ]
}
