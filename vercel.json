{
  "framework": "hugo",
  "buildCommand": "hugo --gc --minify",
  "outputDirectory": "public",
  "git": {
    "deploymentEnabled": {
      "master": true
    }
  },
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.dungeonpath.com"
        }
      ],
      "destination": "https://dungeonpath.com/$1",
      "statusCode": 301
    }
  ]
}
